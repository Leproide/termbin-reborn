# ══════════════════════════════════════════════════════════════════════════════
#  Termbin – central configuration
#  Copy this file to .env and edit as needed. Do NOT commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════


# ── Public domain ─────────────────────────────────────────────────────────────
# Used by fiche (returned URL prefix) and nginx (server_name)
FICHE_DOMAIN=changeme.com


# ── TCP port fiche listens on ─────────────────────────────────────────────────
FICHE_PORT=9999


# ── fiche options ─────────────────────────────────────────────────────────────
#
#   -S            return https:// links instead of http://
#   -s <n>        slug length (default: 4)
#   -B <bytes>    max upload size in bytes (default: 32768)
#                 10 MB = 10485760
#   -l <path>     log file path inside the container
#   -L <addr>     address to listen on (default: 0.0.0.0)
#   -p <port>     listening port (default: 9999) — only needed if different from FICHE_PORT
#   -u <user>     drop privileges to this user after bind (requires root at start)
#   -P <port>     delete service port (0 = disabled)
#
#   NOT IMPLEMENTED YET — do not use:
#   # -b <file>   ban list (one IP per line)
#   # -w <file>   whitelist (one IP per line); blocks everyone else if set
#
FICHE_ARGS=-S -s 16 -B 10485760 -l /data/log/fiche.log -P 9998


# ── Delete service port ───────────────────────────────────────────────────────
# fiche listens here for delete requests: echo -e "slug\ntoken" | nc domain 9998
FICHE_DELETE_PORT=9998


# ── nginx internal HTTP port ──────────────────────────────────────────────────
# Exposed on loopback only; your reverse proxy (Apache/Caddy/…) fronts it
NGINX_PORT=62365
